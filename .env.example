# Copy this file to .env and fill in your own values. .env is gitignored —
# never commit real credentials. See docs/specs/translations/README.md for
# what these are for and why they live here instead of in the repo.

# Current Weblate instance (proof-of-concept, not the permanent home —
# expect this to change; see docs/specs/translations/README.md).
WEBLATE_URL=https://weblate.tend.farband.ca

# Personal API token, if/when Weblate CLI or API automation is used.
# Not your web login password — this is a separate token issued per user
# from within Weblate itself (Settings > API access) once you have an account.
WEBLATE_API_TOKEN=
